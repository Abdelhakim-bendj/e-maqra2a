generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum TaskType {
  NEW
  REVISION
}

enum TaskStatus {
  ASSIGNED
  COMPLETED
  OVERDUE
}

enum SubmissionStatus {
  PENDING
  REVIEWED
  REVISION_NEEDED
}

enum ExamType {
  WEEKLY
  MONTHLY
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum SessionType {
  MEMORIZATION
  TAJWEED
  EDUCATIONAL
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
}

enum NotificationType {
  ANNOUNCEMENT
  PRIVATE
  AUTO
}

enum TajweedCategory {
  MAKHARIJ
  SIFAAT
  NOON_SAKINAH
  MEEM_SAKINAH
  MADD
  GHUNNA
}

enum ContentCategory {
  SUPPLICATION
  SEERAH
  COMPANION
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  fullName      String   @map("full_name")
  role          Role     @default(STUDENT)
  phone         String?
  avatarUrl     String?  @map("avatar_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  studentProfile     StudentProfile?
  taughtClasses      Class[]            @relation("TeacherClasses")
  createdClasses     Class[]            @relation("CreatedClasses")
  assignedTasks      MemorizationTask[] @relation("TeacherTasks")
  receivedTasks      MemorizationTask[] @relation("StudentTasks")
  createdExams       Exam[]             @relation("TeacherExams")
  hostedSessions     LiveSession[]      @relation("TeacherSessions")
  sentNotifications  Notification[]     @relation("SentNotifications")
  receivedNotifs     Notification[]     @relation("ReceivedNotifications")
  sentMessages       Message[]          @relation("SentMessages")
  receivedMessages   Message[]          @relation("ReceivedMessages")
  createdLessons     TajweedLesson[]    @relation("CreatedLessons")
  attendances        Attendance[]
  examSubmissions    ExamSubmission[]
  memorizationSubmissions MemorizationSubmission[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs          AuditLog[]

  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdByIp String?   @map("created_by_ip")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model StudentProfile {
  id             String    @id @default(uuid())
  userId         String    @unique @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollmentDate DateTime? @default(now()) @map("enrollment_date")
  teacherId      String?   @map("teacher_id")
  classId        String?   @map("class_id")
  class          Class?    @relation(fields: [classId], references: [id])
  currentJuz     Int?      @map("current_juz")
  currentSurah   Int?      @map("current_surah")
  notes          String?

  @@index([teacherId])
  @@index([classId])
  @@map("student_profiles")
}

model Class {
  id          String   @id @default(uuid())
  name        String
  description String?
  teacherId   String?  @map("teacher_id")
  teacher     User?    @relation("TeacherClasses", fields: [teacherId], references: [id])
  createdBy   String?  @map("created_by")
  creator     User?    @relation("CreatedClasses", fields: [createdBy], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  students    StudentProfile[]

  @@index([teacherId])
  @@map("classes")
}

model MemorizationTask {
  id           String     @id @default(uuid())
  teacherId    String     @map("teacher_id")
  teacher      User       @relation("TeacherTasks", fields: [teacherId], references: [id])
  studentId    String     @map("student_id")
  student      User       @relation("StudentTasks", fields: [studentId], references: [id])
  taskType     TaskType   @map("task_type")
  surahNumber  Int        @map("surah_number")
  ayahStart    Int        @map("ayah_start")
  ayahEnd      Int        @map("ayah_end")
  assignedDate DateTime   @default(now()) @map("assigned_date")
  dueDate      DateTime   @map("due_date")
  status       TaskStatus @default(ASSIGNED)
  notes        String?

  submissions  MemorizationSubmission[]

  @@index([teacherId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@map("memorization_tasks")
}

model MemorizationSubmission {
  id           String           @id @default(uuid())
  taskId       String           @map("task_id")
  task         MemorizationTask @relation(fields: [taskId], references: [id])
  studentId    String           @map("student_id")
  student      User             @relation(fields: [studentId], references: [id])
  audioUrl     String           @map("audio_url")
  submittedAt  DateTime         @default(now()) @map("submitted_at")
  status       SubmissionStatus @default(PENDING)
  teacherNotes String?          @map("teacher_notes")

  assessment   Assessment?

  @@index([taskId])
  @@index([studentId])
  @@index([status])
  @@map("memorization_submissions")
}

model Assessment {
  id                String                 @id @default(uuid())
  submissionId      String                 @unique @map("submission_id")
  submission        MemorizationSubmission @relation(fields: [submissionId], references: [id])
  memorizationScore Int?                   @map("memorization_score")
  tajweedScore      Int?                   @map("tajweed_score")
  fluencyScore      Int?                   @map("fluency_score")
  overallScore      Int?                   @map("overall_score")
  feedback          String?
  assessedAt        DateTime               @default(now()) @map("assessed_at")

  @@index([submissionId])
  @@map("assessments")
}

model Exam {
  id               String     @id @default(uuid())
  title            String
  description      String?
  examType         ExamType   @map("exam_type")
  teacherId        String     @map("teacher_id")
  teacher          User       @relation("TeacherExams", fields: [teacherId], references: [id])
  startTime        DateTime   @map("start_time")
  endTime          DateTime   @map("end_time")
  timeLimitMinutes Int        @map("time_limit_minutes")
  passingScore     Int        @map("passing_score")
  status           ExamStatus @default(DRAFT)

  questions        Question[]
  submissions      ExamSubmission[]

  @@index([teacherId])
  @@index([status])
  @@map("exams")
}

model Question {
  id            String       @id @default(uuid())
  examId        String       @map("exam_id")
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionType  QuestionType @map("question_type")
  questionText  String       @map("question_text")
  options       Json?        // For multiple choice
  correctAnswer String       @map("correct_answer")
  points        Int
  orderIndex    Int          @map("order_index")

  answers       Answer[]

  @@index([examId])
  @@map("questions")
}

model ExamSubmission {
  id          String   @id @default(uuid())
  examId      String   @map("exam_id")
  exam        Exam     @relation(fields: [examId], references: [id])
  studentId   String   @map("student_id")
  student     User     @relation(fields: [studentId], references: [id])
  startedAt   DateTime @default(now()) @map("started_at")
  submittedAt DateTime? @map("submitted_at")
  totalScore  Int?     @map("total_score")
  status      String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED

  answers     Answer[]

  @@index([examId])
  @@index([studentId])
  @@map("exam_submissions")
}

model Answer {
  id            String         @id @default(uuid())
  submissionId  String         @map("submission_id")
  submission    ExamSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId    String         @map("question_id")
  question      Question       @relation(fields: [questionId], references: [id])
  studentAnswer String         @map("student_answer")
  isCorrect     Boolean?       @map("is_correct")
  pointsAwarded Int?           @map("points_awarded")

  @@index([submissionId])
  @@index([questionId])
  @@map("answers")
}

model LiveSession {
  id              String        @id @default(uuid())
  title           String
  description     String?
  sessionType     SessionType   @map("session_type")
  teacherId       String        @map("teacher_id")
  teacher         User          @relation("TeacherSessions", fields: [teacherId], references: [id])
  scheduledAt     DateTime      @map("scheduled_at")
  durationMinutes Int           @map("duration_minutes")
  maxParticipants Int           @map("max_participants")
  meetingUrl      String?       @map("meeting_url")
  status          SessionStatus @default(SCHEDULED)

  attendances     Attendance[]

  @@index([teacherId])
  @@index([scheduledAt])
  @@index([status])
  @@map("live_sessions")
}

model Attendance {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  session   LiveSession @relation(fields: [sessionId], references: [id])
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id])
  joinedAt  DateTime    @default(now()) @map("joined_at")
  leftAt    DateTime?   @map("left_at")

  @@index([sessionId])
  @@index([userId])
  @@map("attendances")
}

model Notification {
  id          String           @id @default(uuid())
  senderId    String?          @map("sender_id")
  sender      User?            @relation("SentNotifications", fields: [senderId], references: [id])
  recipientId String           @map("recipient_id")
  recipient   User             @relation("ReceivedNotifications", fields: [recipientId], references: [id])
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([recipientId])
  @@index([isRead])
  @@map("notifications")
}

model Message {
  id          String   @id @default(uuid())
  senderId    String   @map("sender_id")
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  recipientId String   @map("recipient_id")
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id])
  content     String
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([senderId])
  @@index([recipientId])
  @@index([isRead])
  @@map("messages")
}

model TajweedLesson {
  id          String          @id @default(uuid())
  title       String
  description String?
  category    TajweedCategory
  content     String          // Rich text / markdown
  videoUrl    String?         @map("video_url")
  pdfUrl      String?         @map("pdf_url")
  orderIndex  Int             @map("order_index")
  createdBy   String          @map("created_by")
  creator     User            @relation("CreatedLessons", fields: [createdBy], references: [id])

  @@map("tajweed_lessons")
}

model IslamicContent {
  id          String          @id @default(uuid())
  title       String
  content     String          // Rich text
  category    ContentCategory
  subcategory String?
  mediaUrls   Json?           @map("media_urls")
  orderIndex  Int             @map("order_index")

  @@map("islamic_content")
}
